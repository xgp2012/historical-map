---
// 搜索框组件
---

<div class="absolute top-6 right-6 z-10" id="search-container">
  <div class="relative">
    <input
      type="text"
      id="year-search"
      placeholder="输入年份（如 -500、1500）"
      class="bg-parchment/80 backdrop-blur-sm border border-gold-dark/30 rounded-lg px-4 py-2 text-sm text-amber-light w-48 focus:outline-none focus:border-gold focus:shadow-[0_0_15px_rgba(201,168,76,0.2)] transition-all duration-300 placeholder:text-amber-light/30 font-body"
    />
    <button
      id="search-btn"
      class="absolute right-2 top-1/2 -translate-y-1/2 text-gold-dark hover:text-gold transition-colors"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
      </svg>
    </button>
  </div>
</div>

<script>
  const searchInput = document.getElementById('year-search') as HTMLInputElement;
  const searchBtn = document.getElementById('search-btn');

  function handleSearch() {
    const value = searchInput?.value.trim();
    if (!value) return;
    
    let year: number;
    
    // 解析输入
    if (value.startsWith('-')) {
      year = parseInt(value);
    } else if (value.includes('公元前')) {
      year = -parseInt(value.replace('公元前', '').replace('年', ''));
    } else if (value.includes('公元')) {
      year = parseInt(value.replace('公元', '').replace('年', ''));
    } else {
      year = parseInt(value);
    }
    
    if (isNaN(year) || year < -3000 || year > 2000) {
      // 提示无效输入
      searchInput.style.borderColor = 'rgba(200, 80, 50, 0.5)';
      setTimeout(() => {
        searchInput.style.borderColor = '';
      }, 1000);
      return;
    }
    
    // 更新滑块
    const slider = document.getElementById('timeline-slider') as HTMLInputElement;
    if (slider) {
      slider.value = year.toString();
      slider.dispatchEvent(new Event('input'));
    }
    
    // 清空输入
    searchInput.value = '';
  }

  searchBtn?.addEventListener('click', handleSearch);
  searchInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      handleSearch();
    }
  });
</script>